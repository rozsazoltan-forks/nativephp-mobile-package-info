{
  "name": "codingwithrk/package-info",
  "description": "A NativePHP Mobile plugin provides an API for querying information about an application package.",
  "type": "nativephp-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "CodingwithRK",
      "email": "pappalarajkumar@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "nativephp/mobile": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Codingwithrk\\PackageInfo\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Codingwithrk\\PackageInfo\\PackageInfoServiceProvider"
      ]
    },
    "nativephp": {
      "manifest": "nativephp.json"
    }
  },
  "require-dev": {
    "pestphp/pest": "^3.0"
  },
  "scripts": {
    "test": "pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}